# TraffiCure prod Postgres — copy this file to `.env` and fill in.
# `.env` is gitignored; `.env.example` is checked in.
#
# The probe and data-pull scripts under data/v2_1/ look for a `.env` at the
# project root and fall back to os.environ if it's missing.

POSTGRES_HOST=192.168.2.86
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
